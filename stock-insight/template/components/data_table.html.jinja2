{# Reusable data table component - Professional Financial Dashboard Style #}
{# Usage: {% include 'components/data_table.html.jinja2' with context %} #}
{# Required variables: headers, rows #}
{# Optional: title, max_rows (for beginner mode) #}

<div class="card overflow-hidden">
    {% if title %}
    <div class="p-4 border-b border-slate-700/50">
        <h3 class="font-semibold text-slate-200">{{ title }}</h3>
    </div>
    {% endif %}

    <div class="overflow-x-auto">
        <table class="data-table">
            <thead>
                <tr>
                    {% for header in headers %}
                    <th class="{{ 'sticky-col' if loop.first }} {{ 'text-right' if not loop.first }}">{{ header }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% set display_rows = rows[:max_rows] if max_rows else rows %}
                {% for row in display_rows %}
                <tr>
                    {% for cell in row %}
                    <td class="{{ 'sticky-col font-medium' if loop.first }} {{ 'text-right font-mono' if not loop.first }}">
                        {{ cell }}
                    </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if max_rows and rows|length > max_rows %}
    <div class="p-3 border-t border-slate-700/30 text-center">
        <p class="text-xs text-slate-500">
            Showing {{ max_rows }} of {{ rows|length }} rows.
        </p>
    </div>
    {% endif %}
</div>
