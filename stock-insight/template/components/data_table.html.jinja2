{# Reusable data table component with sticky first column #}
{# Usage: {% include 'components/data_table.html.jinja2' with context %} #}
{# Required variables: headers, rows #}
{# Optional: title, max_rows (for beginner mode) #}

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    {% if title %}
    <h3 class="text-lg font-semibold mb-4">{{ title }}</h3>
    {% endif %}

    <div class="overflow-x-auto" style="-webkit-overflow-scrolling: touch;">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b dark:border-gray-700">
                    {% for header in headers %}
                    <th class="p-2 text-left {% if loop.first %}sticky-col{% endif %}">{{ header }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% set display_rows = rows[:max_rows] if max_rows else rows %}
                {% for row in display_rows %}
                <tr class="border-b dark:border-gray-700">
                    {% for cell in row %}
                    <td class="p-2 {% if loop.first %}sticky-col font-medium{% endif %} {% if not loop.first %}text-right{% endif %}">
                        {{ cell }}
                    </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if max_rows and rows|length > max_rows %}
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
        Showing {{ max_rows }} of {{ rows|length }} rows.
    </p>
    {% endif %}
</div>