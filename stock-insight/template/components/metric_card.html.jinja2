{# Reusable metric card component - Professional Financial Dashboard Style #}
{# Usage: {% include 'components/metric_card.html.jinja2' with context %} #}
{# Required variables: label, value #}
{# Optional: tooltip, unit, trend, glow (up/down), icon #}

<div class="card metric-card p-4 {% if glow %}glow-{{ glow }}{% endif %}">
    <div class="flex items-center justify-between mb-1">
        <span class="text-xs text-slate-500 uppercase tracking-wider">{{ label }}</span>
        {% if tooltip and is_beginner %}
        <span class="text-slate-600 cursor-help tooltip" data-tooltip="{{ tooltip }}">?</span>
        {% endif %}
        {% if icon %}
        <span class="text-slate-600">{{ icon }}</span>
        {% endif %}
    </div>
    <div class="flex items-baseline gap-2">
        <span class="text-2xl font-bold text-slate-100">
            {% if value is not none %}
            {% if unit == '%' %}
            {{ value|round(1) }}%
            {% elif unit == '$' %}
            ${{ value|round(2) }}
            {% elif unit == 'x' %}
            {{ value|round(2) }}x
            {% else %}
            {{ value }}
            {% endif %}
            {% else %}
            <span class="text-slate-600">N/A</span>
            {% endif %}
        </span>
        {% if trend is defined %}
        <span class="text-sm font-medium {{ 'text-up' if trend >= 0 else 'text-down' }}">
            {{ '%+.1f'|format(trend) }}%
        </span>
        {% endif %}
    </div>
    {% if subtitle %}
    <span class="text-xs text-slate-500 mt-1 block">{{ subtitle }}</span>
    {% endif %}
</div>
