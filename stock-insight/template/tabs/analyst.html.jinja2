{# Analyst Tab - Ratings and price targets #}

{% if analyst %}
<!-- Rating Summary -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 mb-6">
    <h3 class="text-lg font-semibold mb-4">Analyst Consensus</h3>

    {% if analyst.grades %}
    <div class="mb-6">
        <div class="flex h-8 rounded-full overflow-hidden mb-2">
            {% set total = analyst.grades.buy + analyst.grades.hold + analyst.grades.sell %}
            {% if total > 0 %}
            {% set buy_pct = (analyst.grades.buy / total * 100)|round %}
            {% set hold_pct = (analyst.grades.hold / total * 100)|round %}
            {% set sell_pct = (analyst.grades.sell / total * 100)|round %}

            {% if buy_pct > 0 %}
            <div class="bg-green-500 flex items-center justify-center text-white text-xs font-medium" style="width: {{ buy_pct }}%">
                {% if buy_pct > 10 %}{{ analyst.grades.buy }}{% endif %}
            </div>
            {% endif %}
            {% if hold_pct > 0 %}
            <div class="bg-yellow-500 flex items-center justify-center text-white text-xs font-medium" style="width: {{ hold_pct }}%">
                {% if hold_pct > 10 %}{{ analyst.grades.hold }}{% endif %}
            </div>
            {% endif %}
            {% if sell_pct > 0 %}
            <div class="bg-red-500 flex items-center justify-center text-white text-xs font-medium" style="width: {{ sell_pct }}%">
                {% if sell_pct > 10 %}{{ analyst.grades.sell }}{% endif %}
            </div>
            {% endif %}
            {% endif %}
        </div>
        <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400">
            <span class="flex items-center"><span class="w-3 h-3 bg-green-500 rounded-full mr-1"></span> Buy ({{ analyst.grades.buy }})</span>
            <span class="flex items-center"><span class="w-3 h-3 bg-yellow-500 rounded-full mr-1"></span> Hold ({{ analyst.grades.hold }})</span>
            <span class="flex items-center"><span class="w-3 h-3 bg-red-500 rounded-full mr-1"></span> Sell ({{ analyst.grades.sell }})</span>
        </div>
    </div>
    {% endif %}

    <!-- Price Targets -->
    {% if analyst.price_target %}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {% if analyst.price_target.mean %}
        <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded">
            <p class="text-xs text-gray-500 dark:text-gray-400">Mean Target</p>
            <p class="text-xl font-bold">${{ analyst.price_target.mean|round(2) }}</p>
        </div>
        {% endif %}
        {% if analyst.price_target.median %}
        <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded">
            <p class="text-xs text-gray-500 dark:text-gray-400">Median Target</p>
            <p class="text-xl font-bold">${{ analyst.price_target.median|round(2) }}</p>
        </div>
        {% endif %}
        {% if analyst.price_target.high %}
        <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded">
            <p class="text-xs text-gray-500 dark:text-gray-400">High Target</p>
            <p class="text-xl font-bold text-up">${{ analyst.price_target.high|round(2) }}</p>
        </div>
        {% endif %}
        {% if analyst.price_target.low %}
        <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded">
            <p class="text-xs text-gray-500 dark:text-gray-400">Low Target</p>
            <p class="text-xl font-bold text-down">${{ analyst.price_target.low|round(2) }}</p>
        </div>
        {% endif %}
    </div>

    {% if price and price.current_price and analyst.price_target.mean %}
    {% set upside = ((analyst.price_target.mean - price.current_price) / price.current_price * 100)|round(1) %}
    <p class="mt-4 text-sm text-gray-600 dark:text-gray-400">
        Potential upside: <span class="{{ 'text-up' if upside >= 0 else 'text-down' }}">{{ '%+.1f'|format(upside) }}%</span>
    </p>
    {% endif %}
    {% endif %}
</div>

<!-- Recommendation History -->
{% if analyst.history and analyst.history|length > 0 %}
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    <h3 class="text-lg font-semibold mb-4">Recommendation History</h3>
    <div class="overflow-x-auto" style="-webkit-overflow-scrolling: touch;">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b dark:border-gray-700">
                    <th class="p-2 text-left sticky-col">Date</th>
                    <th class="p-2 text-right">Strong Buy</th>
                    <th class="p-2 text-right">Buy</th>
                    <th class="p-2 text-right">Hold</th>
                    <th class="p-2 text-right">Sell</th>
                    <th class="p-2 text-right">Strong Sell</th>
                </tr>
            </thead>
            <tbody>
                {% for rec in analyst.history[:10] %}
                <tr class="border-b dark:border-gray-700">
                    <td class="p-2 sticky-col">{{ (rec.get('index') or rec.get('Date') or rec.get('period'))|string|truncate(10, True, '', 0) }}</td>
                    <td class="p-2 text-right">{{ rec.get('strongBuy', '-') }}</td>
                    <td class="p-2 text-right">{{ rec.get('buy', '-') }}</td>
                    <td class="p-2 text-right">{{ rec.get('hold', '-') }}</td>
                    <td class="p-2 text-right">{{ rec.get('sell', '-') }}</td>
                    <td class="p-2 text-right">{{ rec.get('strongSell', '-') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% else %}
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    <p class="text-gray-500 dark:text-gray-400">Analyst ratings not available for this ticker.</p>
</div>
{% endif %}