{# News Tab - Recent news articles #}

{% if news and news|length > 0 %}
<div class="space-y-4">
    {% for article in (news[:10] if is_beginner else news) %}
    {% if article.get('title') %}
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 hover:shadow-md transition-shadow">
        <div class="flex flex-col">
            <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-gray-500 dark:text-gray-400">
                    {{ article.get('publisher') or article.get('source') or 'Unknown' }}
                </span>
                {% if article.get('published') %}
                <span class="text-xs text-gray-400">
                    {% if article.published is number %}
                    {{ article.published }}
                    {% else %}
                    {{ article.published }}
                    {% endif %}
                </span>
                {% endif %}
            </div>

            {% if article.get('link') and article.link != 'None' and article.link %}
            <a href="{{ article.link }}"
               target="_blank"
               rel="noopener noreferrer"
               class="text-lg font-medium text-gray-900 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400">
                {{ article.get('title', 'No title') }}
            </a>
            {% else %}
            <span class="text-lg font-medium text-gray-900 dark:text-gray-100">
                {{ article.get('title', 'No title') }}
            </span>
            {% endif %}

            {% if article.get('summary') and is_beginner %}
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
                {{ article.summary[:200] }}{% if article.summary|length > 200 %}...{% endif %}
            </p>
            {% endif %}
        </div>
    </div>
    {% endif %}
    {% endfor %}
</div>

{% if news|length > 10 and is_beginner %}
<p class="text-center text-sm text-gray-500 dark:text-gray-400 mt-4">
    Showing 10 of {{ news|length }} articles. Switch to Advanced mode for all articles.
</p>
{% endif %}

{% else %}
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    <p class="text-gray-500 dark:text-gray-400">No recent news available for this ticker.</p>
</div>
{% endif %}