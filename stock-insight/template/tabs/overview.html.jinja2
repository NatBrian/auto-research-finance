{# Overview Tab - Company profile, price cards, performance #}

{% if profile and profile.description %}
<div class="mb-6 p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
    <h3 class="text-lg font-semibold mb-2">About {{ profile.name or ticker }}</h3>
    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
        {{ profile.description[:500] }}{% if profile.description|length > 500 %}...{% endif %}
    </p>
    {% if profile.sector or profile.industry %}
    <div class="mt-3 flex flex-wrap gap-2">
        {% if profile.sector %}
        <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs rounded">{{ profile.sector }}</span>
        {% endif %}
        {% if profile.industry %}
        <span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs rounded">{{ profile.industry }}</span>
        {% endif %}
    </div>
    {% endif %}
</div>
{% endif %}

{% if price %}
<!-- Price Cards -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="metric-card p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">Price</p>
        <p class="text-2xl font-bold">${{ price.get('current_price', 'N/A')|round(2) if price.get('current_price') else 'N/A' }}</p>
        {% if price.get('change_pct') is not none %}
        <p class="text-sm {{ 'text-up' if price.get('change_pct', 0) >= 0 else 'text-down' }}">
            {{ '%+.2f'|format(price.get('change_pct', 0)) }}%
        </p>
        {% endif %}
    </div>

    <div class="metric-card p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">Volume</p>
        <p class="text-2xl font-bold">{{ price.volume|format_number if price.volume else 'N/A' }}</p>
        {% if price.avg_volume %}
        <p class="text-sm text-gray-500">Avg: {{ price.avg_volume|format_number }}</p>
        {% endif %}
    </div>

    <div class="metric-card p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">Market Cap</p>
        <p class="text-2xl font-bold">{{ price.market_cap|format_number if price.market_cap else 'N/A' }}</p>
    </div>

    <div class="metric-card p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">52W Range</p>
        {% if price.high_52w and price.low_52w %}
        <div class="mt-2">
            <div class="flex justify-between text-xs text-gray-500 mb-1">
                <span>${{ price.low_52w|round(2) }}</span>
                <span>${{ price.high_52w|round(2) }}</span>
            </div>
            <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded-full relative">
                {% set range = price.high_52w - price.low_52w %}
                {% if range > 0 and price.current_price %}
                {% set position = ((price.current_price - price.low_52w) / range * 100)|round %}
                <div class="absolute h-full bg-blue-500 rounded-full" style="width: {{ position }}%"></div>
                <div class="absolute w-3 h-3 bg-blue-600 rounded-full -top-0.5 transform -translate-x-1/2" style="left: {{ position }}%"></div>
                {% endif %}
            </div>
        </div>
        {% else %}
        <p class="text-lg">N/A</p>
        {% endif %}
    </div>
</div>

<!-- Price Chart -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 mb-6">
    <h3 class="text-lg font-semibold mb-4">Price History</h3>
    <div id="price-chart" style="width: 100%; height: 500px;"></div>
</div>

<!-- Performance Chart -->
{% if charts.performance %}
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 mb-6">
    <h3 class="text-lg font-semibold mb-4">Performance</h3>
    <div id="performance-chart" style="width: 100%; height: 250px;"></div>
</div>
{% endif %}
{% endif %}

<!-- Company Info -->
{% if profile %}
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    <h3 class="text-lg font-semibold mb-4">Company Information</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
        {% if profile.exchange %}
        <div>
            <p class="text-gray-500 dark:text-gray-400">Exchange</p>
            <p class="font-medium">{{ profile.exchange }}</p>
        </div>
        {% endif %}
        {% if profile.country %}
        <div>
            <p class="text-gray-500 dark:text-gray-400">Country</p>
            <p class="font-medium">{{ profile.country }}</p>
        </div>
        {% endif %}
        {% if profile.employees %}
        <div>
            <p class="text-gray-500 dark:text-gray-400">Employees</p>
            <p class="font-medium">{{ profile.employees|format_number }}</p>
        </div>
        {% endif %}
        {% if profile.website %}
        <div class="col-span-2 md:col-span-3">
            <p class="text-gray-500 dark:text-gray-400">Website</p>
            <a href="{{ profile.website }}" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">{{ profile.website }}</a>
        </div>
        {% endif %}
    </div>
</div>
{% endif %}