{# Ownership Tab - Institutional holders #}

{% if ownership and ownership.holders %}
<!-- Ownership Summary -->
<div class="grid grid-cols-2 gap-4 mb-6">
    <div class="metric-card p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">
            {{ 'Institutional Holders' if is_beginner else 'Institutions' }}
        </p>
        <p class="text-2xl font-bold mt-1">{{ ownership.total_institutions or ownership.holders|length }}</p>
    </div>
    <div class="metric-card p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
        <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">
            {{ 'Top Holder %' if is_beginner else 'Top %' }}
        </p>
        {% set top_holder = ownership.holders[0] if ownership.holders else {} %}
        <p class="text-2xl font-bold mt-1">
            {% set pct = top_holder.get('% Out') or top_holder.get('pctHeld') %}
            {% if pct %}
            {{ (pct * 100 if pct < 1 else pct)|round(2) }}%
            {% else %}
            N/A
            {% endif %}
        </p>
    </div>
</div>

<!-- Ownership Chart -->
{% if charts.ownership %}
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 mb-6">
    <h3 class="text-lg font-semibold mb-4">Top Institutional Holders</h3>
    <div id="ownership-chart" style="width: 100%; height: 400px;"></div>
</div>
{% endif %}

<!-- Holders Table -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    <h3 class="text-lg font-semibold mb-4">Institutional Holdings</h3>
    <div class="overflow-x-auto" style="-webkit-overflow-scrolling: touch;">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b dark:border-gray-700">
                    <th class="p-2 text-left sticky-col">Holder</th>
                    <th class="p-2 text-right">Shares</th>
                    <th class="p-2 text-right">% Out</th>
                    <th class="p-2 text-right">Value</th>
                </tr>
            </thead>
            <tbody>
                {% for holder in (ownership.holders[:10] if is_beginner else ownership.holders) %}
                <tr class="border-b dark:border-gray-700">
                    <td class="p-2 sticky-col font-medium">
                        {{ (holder.get('Holder') or holder.get('holder', 'Unknown'))[:40] }}
                    </td>
                    <td class="p-2 text-right">
                        {% set shares = holder.get('Shares') or holder.get('shares') %}
                        {% if shares %}
                        {{ shares|format_number }}
                        {% else %}
                        -
                        {% endif %}
                    </td>
                    <td class="p-2 text-right">
                        {% set pct = holder.get('% Out') or holder.get('pctOut') or holder.get('pctHeld') %}
                        {% if pct %}
                        {{ (pct * 100 if pct < 1 else pct)|round(2) }}%
                        {% else %}
                        -
                        {% endif %}
                    </td>
                    <td class="p-2 text-right">
                        {% set value = holder.get('Value') or holder.get('value') %}
                        {% if value %}
                        {{ value|format_number }}
                        {% else %}
                        -
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% else %}
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    <p class="text-gray-500 dark:text-gray-400">Institutional ownership data not available for this ticker.</p>
</div>
{% endif %}