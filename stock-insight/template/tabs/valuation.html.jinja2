{# Valuation Tab - P/E, P/B, P/S, P/CF ratios #}

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    {% for metric_key in ['pe_ratio', 'pb_ratio', 'ps_ratio', 'pcf_ratio'] %}
    {% set metric = metrics.get(metric_key, {}) %}
    {% set label = metric.get('label', {}) %}
    <div class="metric-card p-4 bg-white dark:bg-gray-800 rounded-lg shadow">
        <div class="flex items-center justify-between">
            <p class="text-xs text-gray-500 dark:text-gray-400 uppercase">
                {{ label.get('display', metric_key) }}
            </p>
            {% if is_beginner and label.get('tooltip') %}
            <span class="text-gray-400 cursor-help" title="{{ label.tooltip }}">ℹ️</span>
            {% endif %}
        </div>
        <p class="text-2xl font-bold mt-1">
            {% if metric and metric.get('value') is not none %}
            {{ metric.get('value')|round(2) }}
            {% else %}
            N/A
            {% endif %}
        </p>
    </div>
    {% endfor %}
</div>

<!-- Valuation Context -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 mb-6">
    <h3 class="text-lg font-semibold mb-4">Valuation Analysis</h3>

    {% if metrics.get('pe_ratio') and metrics.pe_ratio.get('value') %}
    <div class="mb-4">
        <h4 class="font-medium text-gray-700 dark:text-gray-300">Price-to-Earnings (P/E)</h4>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            {{ metrics.pe_ratio.value|round(2) }}x earnings
            {% if is_beginner %}
            — Measures how much investors pay for each dollar of earnings. Lower P/E may indicate undervaluation.
            {% endif %}
        </p>
    </div>
    {% endif %}

    {% if metrics.get('pb_ratio') and metrics.pb_ratio.get('value') %}
    <div class="mb-4">
        <h4 class="font-medium text-gray-700 dark:text-gray-300">Price-to-Book (P/B)</h4>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            {{ metrics.pb_ratio.value|round(2) }}x book value
            {% if is_beginner %}
            — Compares market value to book value. P/B &lt; 1 may suggest the stock is undervalued.
            {% endif %}
        </p>
    </div>
    {% endif %}

    {% if metrics.get('ps_ratio') and metrics.ps_ratio.get('value') %}
    <div class="mb-4">
        <h4 class="font-medium text-gray-700 dark:text-gray-300">Price-to-Sales (P/S)</h4>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            {{ metrics.ps_ratio.value|round(2) }}x revenue
            {% if is_beginner %}
            — Useful for companies without profits. Lower P/S suggests better value.
            {% endif %}
        </p>
    </div>
    {% endif %}

    {% if metrics.get('pcf_ratio') and metrics.pcf_ratio.get('value') %}
    <div class="mb-4">
        <h4 class="font-medium text-gray-700 dark:text-gray-300">Price-to-Cash Flow (P/CF)</h4>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
            {{ metrics.pcf_ratio.value|round(2) }}x cash flow
            {% if is_beginner %}
            — Uses cash flow instead of earnings, which is harder to manipulate.
            {% endif %}
        </p>
    </div>
    {% endif %}

    {% if not metrics.get('pe_ratio', {}).get('value') and not metrics.get('pb_ratio', {}).get('value') and not metrics.get('ps_ratio', {}).get('value') %}
    <p class="text-gray-500 dark:text-gray-400">Valuation metrics not available for this ticker.</p>
    {% endif %}
</div>

{% if is_advanced %}
<!-- Advanced Valuation Metrics -->
<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4">
    <h3 class="text-lg font-semibold mb-4">Advanced Metrics</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
        {% if metrics.peg_ratio is defined %}
        <div>
            <p class="text-gray-500 dark:text-gray-400">PEG Ratio</p>
            <p class="font-medium">{{ metrics.peg_ratio.value|round(2) if metrics.peg_ratio.value else 'N/A' }}</p>
        </div>
        {% endif %}
        {% if metrics.ev_ebitda is defined %}
        <div>
            <p class="text-gray-500 dark:text-gray-400">EV/EBITDA</p>
            <p class="font-medium">{{ metrics.ev_ebitda.value|round(2) if metrics.ev_ebitda.value else 'N/A' }}</p>
        </div>
        {% endif %}
    </div>
</div>
{% endif %}