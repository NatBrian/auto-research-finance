# API Keys for Fallback Data Sources
# yfinance: No API key required (primary source, unlimited)

# Twelve Data: Free tier = 800 calls/day, 8 calls/minute
# Get your key at: https://twelvedata.com/pricing
TWELVEDATA_API_KEY=your_key_here

# Finnhub: Free tier = 60 calls/minute
# Get your key at: https://finnhub.io/register
FINNHUB_API_KEY=your_key_here

# Default Settings
DEFAULT_SUFFIX=JK
DEFAULT_MODE=beginner

# SSL Verification (set to false for proxy environments)
SSL_VERIFY=false